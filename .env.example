# Path Configuration
CONFIG_ROOT=/path/to/config
MEDIA_ROOT=/path/to/media
DOWNLOADS_ROOT=/path/to/downloads

# Tailscale Auth Key
# Generate a reusable key at https://login.tailscale.com/admin/settings/keys
# Keys expire after max 90 days, but persisted state survives beyond expiry
TS_AUTHKEY=your_tailscale_auth_key_here

# the "hostname" of the `ts-remote-access` container. 
# Basically - what do you want tailscale to show this as? just a name
TS_HOSTNAME=media-server

# Wireguard Settings
# Generate private key here: https://account.proton.me/u/0/vpn/WireGuard
# Platform: Windows
# Options: disable moderate NAT; enable NAT-PMP (port forwarding); enable VPN Accelerator
WG_PRIVATE_KEY=your_private_key_here

# Gluetun API Key
# Used for managing the gluetun control server
# Generate with `docker run --rm qmcgaw/gluetun genkey`
GLUETUN_API_KEY=your_gluetun_api_key_here

# qBittorrent Credentials
QBITTORRENT_USER=your_username
QBITTORRENT_PASS=your_password

# region books
## CWA
HARDCOVER_API_KEY=your_hardcover_api_key_here
## Shelfmark
# endregion